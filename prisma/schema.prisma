generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Course {
  id        String @id @default(cuid())
  name      String
  code      String?
  color     String
  createdAt DateTime @default(now())
  tasks     Task[]
}

model Task {
  id          String        @id @default(cuid())
  title       String
  description String?
  deadline    DateTime
  status      TaskStatus   @default(NOT_STARTED)
  priority    TaskPriority @default(MEDIUM)
  course      Course       @relation(fields: [courseId], references: [id])
  courseId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}
